# Supabase (for file uploads via Storage)
# Find these in your Supabase dashboard: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://somcokmysaldtchyknlu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Also set as server-side env vars (for route handlers):
SUPABASE_ANON_KEY=your_supabase_anon_key

# Create a bucket called "uploads" in your Supabase dashboard:
# Storage -> Create bucket -> Name: uploads -> Public bucket: ON

# Vercel KV (Upstash Redis) for data storage (optional, falls back to JSON files)
# Get these from your Vercel dashboard: Storage -> KV -> Connect Store
KV_REST_API_URL=
KV_REST_API_TOKEN=

# For local development, only Supabase is needed for cloud uploads.
# Without Supabase env vars, files save to public/uploads/
# Data always falls back to src/data/*.json files.
