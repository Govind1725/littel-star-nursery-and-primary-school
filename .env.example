# Vercel Blob Storage (for production file uploads)
# Get these from your Vercel dashboard: Storage -> Blob -> Connect Store
BLOB_READ_WRITE_TOKEN=

# Vercel KV (Upstash Redis) for data storage (for production)
# Get these from your Vercel dashboard: Storage -> KV -> Connect Store
KV_REST_API_URL=
KV_REST_API_TOKEN=

# For local development, no environment variables are needed.
# Uploads will be saved to public/uploads/
# Data will be stored in src/data/*.json
