# === SUPABASE (required in production) ===
# Find these in your Supabase dashboard: Project Settings -> API

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://somcokmysaldtchyknlu.supabase.co

# Anon key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (secret, for server-side only — get from Supabase dashboard)
# If not set, falls back to SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=

# === SETUP INSTRUCTIONS ===
# 1. Copy to .env.local and fill in values
# 2. Run supabase-migration.sql in Supabase SQL Editor to create tables
# 3. Create a public bucket called "uploads" in Supabase Storage
#
# Without env vars, data stores in src/data/*.json (local dev only)
# and uploads save to public/uploads/ (local dev only).
